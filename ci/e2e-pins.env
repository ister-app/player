# Pins for the integration-e2e workflow: which chart, testdata and server build the
# player is tested against. Sourced as shell variables by workflow.yml.
#
# Keep these hard so player builds are replayable:
# - CHART_REF: a chart release tag (vX.Y.Z) or commit sha of ister-app/chart.
# - TESTDATA_REF: a commit sha of ister-app/testdata (fixtures have no releases).
# - SERVER_IMAGE_TAG: normally EMPTY — then the server (and migrations) version comes
#   from the chart itself (its pinned appVersion/server.image.tag), which is the version
#   the chart was released and tested with. Only set it to try the player against a
#   different server build: a release version ("1.1.0") or the next snapshot
#   ("1.2.0-snapshot", published by the server repo's docker-publish workflow on every
#   push to main — note that a -SNAPSHOT tag is mutable and moves with main).
#
CHART_REF=v0.3.1
TESTDATA_REF=7fe5c58b4aee01505900a30ba45503c9d70df11c
SERVER_IMAGE_TAG=
